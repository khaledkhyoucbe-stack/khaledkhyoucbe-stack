# ════════════════════════════════════
# انسخ هذا الملف وسمّه .env
# ثم غيّر القيم حسب بيئتك
# لا ترفع ملف .env على GitHub أبداً!
# ════════════════════════════════════

# مفتاح التشفير — غيّره لقيمة عشوائية
SECRET_KEY=your-secret-key-here-change-this

# إعدادات Flask
FLASK_ENV=production
FLASK_DEBUG=False

# قاعدة البيانات
DB_PATH=maarif.db

# المجلدات
BACKUP_FOLDER=backups
UPLOAD_FOLDER=uploads

# المنفذ
PORT=5000
